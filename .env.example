ALPHA_VANTAGE_API_KEY=API_KEY
EIA_API_KEY=API_KEY

# Google Gemini — optional priority cloud reasoning layer.
#
# Two keys are supported. If neither is set, behaviour is unchanged
# (free-llm-api-keys → local Ollama).
#
# GEMINI_API_KEY      — FREE Tier. Used for web-summary, and as the fallback
#                      when the paid tier is exhausted. Gemini 2.5 Pro is
#                      unavailable on the free tier.
# GEMINI_API_KEY_PAY  — PAID Tier 1. Used for the high-value use-cases
#                      (decision + vision); Gemini 2.5 Pro anchors the
#                      reasoning cascade. Bounded by the monthly cost budget.
#
# At least one key makes the gateway useful. Get keys at
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_API_KEY_PAY=

# --- Billing protection for the PAID tier --------------------------------
# Rolling 30-day cost budget in EUR (load-bearing). Each paid call's cost is
# computed from actual token usage × the model's price and accumulated; when
# the 30-day sum hits this budget, all paid models are blocked and calls fall
# back to the free tier / Ollama. Default calibrated to 8.6 €/month (June 2026).
# GEMINI_PAY_MONTHLY_BUDGET_EUR=8.6
#
# Hard daily cap on the NUMBER of paid calls (backstop against runaway loops;
# NOT a billing guard — the monthly budget above is). Default: 200 calls/day.
# GEMINI_PAY_DAILY_CAP=200

# Optional — disable the 5MB capped LLM debug dump in data_cache/llm_debug_fail.txt
# TRADING_DEBUG_DUMP=0

# Recommended for parallel LLM calls — lets Ollama serve multiple slots concurrently.
# Defaults to 1 if unset. Higher values increase memory footprint (KV cache × slots).
# OLLAMA_NUM_PARALLEL=8

ALPHA_VANTAGE_API_KEY=API_KEY
EIA_API_KEY=API_KEY

# Google Gemini (Free Tier) — optional priority cloud reasoning layer.
# If set, Gemini is tried first (gemini-2.5-pro decision / -flash vision /
# -flash-lite web summary), then the pipeline falls back to free-llm-api-keys
# and finally local Ollama. If unset, behaviour is unchanged (free-llm → Ollama).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional — disable the 5MB capped LLM debug dump in data_cache/llm_debug_fail.txt
# TRADING_DEBUG_DUMP=0

# Recommended for parallel LLM calls — lets Ollama serve multiple slots concurrently.
# Defaults to 1 if unset. Higher values increase memory footprint (KV cache × slots).
# OLLAMA_NUM_PARALLEL=8
